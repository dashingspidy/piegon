<section>
  <div class="flex items-center justify-between">
    <h1 class="text-xl">List of Subscribers</h1>
    <div class="flex gap-1">
      <%= render "widget_modal" %>
      <%= render "upload_modal" %>
      <%= link_to "Send", "#", class: "btn btn-neutral" %>
    </div>
  </div>
  <div class="overflow-x-auto rounded-box border border-base-content/5 bg-base-100 mt-4">
    <table class="table">
      <thead>
        <tr>
          <th>Email</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @subscribers.each do |subscriber| %>
          <tr>
            <td><%= subscriber.email %></td>
            <td><%= link_to "Delete", contact_subscriber_path(subscriber.contact, subscriber), class: "link link-error", data: { turbo_method: :delete } %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <div class="flex items-center justify-center mt-4">
    <%== pagy_nav(@pagy) %>
  </div>
</section>
