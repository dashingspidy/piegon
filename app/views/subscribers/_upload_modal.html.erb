<button class="btn btn-secondary" onclick="csv_modal.showModal()">Upload CSV</button>
<dialog id="csv_modal" class="modal">
  <div class="modal-box w-11/12 max-w-2xl">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <%= render "subscribers/csv_upload_modal_content" %>
  </div>
</dialog>