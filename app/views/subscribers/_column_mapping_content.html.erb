<%= turbo_frame_tag "modal_form_content" do %>
  <%= form_with url: parse_csv_contact_subscribers_path,
                data: { controller: "mapping", action: "mapping#submit" } do |form| %>
    <section>
      <h2 class="font-bold">Please select the column in your CSV that contains the email addresses</h2>
      <% @columns.each do |column| %>
        <div class="flex justify-between gap-2 mt-2">
          <div>
            Select your <span class="text-error"><%= column.humanize %></span> field:
          </div>
          <div>
            <%= select_tag "column_mapping[#{column}]",
                          options_for_select(@headers),
                          prompt: "Select CSV column",
                          class: "select select-secondary" %>
          </div>
        </div>
      <% end %>
    </section>
    <%= form.submit "Import", class: "btn btn-neutral w-full mt-4" %>
  <% end %>
<% end %>
