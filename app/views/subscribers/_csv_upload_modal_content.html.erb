<div class="p-5">
  <%= turbo_frame_tag "modal_form_content" do %>
    <%= form_with model: @csv_upload, 
                  url: upload_campaign_subscribers_path, 
                  data: { controller: "upload", action: "upload#submit" } do |form| %>
      <div class="grid gap-4 mb-4">
        <%= form.file_field :csv_file, 
                           direct_upload: true,
                           data: { upload_target: "file" } %>
      </div>
      <%= form.submit "Upload", 
                     class: "w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center" %>
    <% end %>
  <% end %>
</div>