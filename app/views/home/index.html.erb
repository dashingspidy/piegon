<section class="flex flex-col items-center justify-center p-20 h-96" id="home">
  <h1 class="text-5xl font-bold">Pay Only for Your Outreach</h1>
  <h5 class="text-2xl mt-4">Grow Your Audience Without Limits</h5>
  <p class="text-xl mt-4">Expand your audience effortlessly and pay only for the outreach you make—simple, transparent, and limitless growth</p>
  <%= link_to "Get started", "#pricing", class: "font-sans text-lg btn-getting mt-10 bg-prim p-4" %>    
</section>

<section class="grid grid-cols-3 mt-20" id="features">
  <div class="bg-prim p-3">
    <h5 class="text-xl my-3">Subscriber Widgets</h5>
    <p>Boost your audience effortlessly with sleek, customizable widgets that integrate seamlessly into any website. Attract and manage subscribers like never before.</p>
    <div class="mt-20">
      <%= image_tag("widget.png") %>
    </div>
  </div>
  <div class="bg-link-water p-3">
    <h5 class="text-xl my-3">Scalable Bulk Emailing</h5>
    <p>Reach thousands—or millions—of inboxes with confidence. Our powerful infrastructure ensures fast, reliable, and secure email delivery at any scale.</p>
    <%= image_tag("bulk_email.svg") %>
  </div>
  <div class="bg-lavender-gray p-3">
    <h5 class="text-xl my-3">Flexible Email Templates</h5>
    <p>Create emails that impress. Use your own designs or craft professional campaigns in minutes with our intuitive drag-and-drop editor.</p>
    <%= image_tag("drag.svg")%>
  </div>
</section>

<section id="pricing" class="p-6">
  <div class="flex flex-wrap justify-between gap-8">
    <div class="w-full max-w-md">
      <h1 class="text-5xl font-thin leading-10 mt-3">Our pricing plan</h1>
      <p class="text-base leading-5 mt-5">Find the perfect plan to match your email marketing needs.</p>
      <div class="w-56 mt-10">
        <button class="bg-gray-100 shadow flex items-center rounded-full">
          <div class="bg-chambray text-white rounded-full py-4 px-6">Annually</div>
        </button>
      </div>
    </div>

    <div class="flex-1 flex flex-col gap-3">
      <%= link_to new_registration_path(plan: "whisper") do %>
        <div class="bg-prim shadow rounded-lg p-8">
          <div class="flex flex-wrap justify-between items-center">
            <h2 class="text-2xl font-logo font-semibold">Whisper <span class="text-base font-medium">10K email per month</span></h2>
            <p class="text-2xl font-semibold">$99</p>
          </div>
          <p class="text-base mt-4">Perfect for small businesses taking their first steps in email marketing.</p>
        </div>
      <% end %>

      <%= link_to new_registration_path(plan: "echo") do %>
        <div class="bg-link-water shadow rounded-lg p-8">
          <div class="flex flex-wrap justify-between items-center">
            <h2 class="text-2xl font-logo font-semibold">Echo <span class="text-base font-medium">30K email per month</span></h2>
            <p class="text-2xl font-semibold">$199</p>
          </div>
          <p class="text-base mt-4">Designed for growing teams ready to expand their audience and impact.</p>
        </div>
      <% end %>
      
      <%= link_to new_registration_path(plan: "resonance") do %>
        <div class="bg-lavender-gray shadow rounded-lg p-8">
          <div class="flex flex-wrap justify-between items-center">
            <h2 class="text-2xl font-logo font-semibold">Resonance <span class="text-base font-medium">50K email per month</span></h2>
            <p class="text-2xl font-semibold">$399</p>
          </div>
          <p class="text-base mt-4">Designed for advanced marketers and mid-sized teams.</p>
        </div>
      <% end %>

      <%= link_to new_registration_path(plan: "payandgo") do %>
        <div class="bg-ship-cove shadow rounded-lg p-8">
          <div class="flex flex-wrap justify-between items-center">
            <h2 class="text-2xl font-logo font-semibold">Solo <span class="text-base font-medium">1000 email for 1$</span></h2>
            <p class="text-2xl font-semibold">$20</p>
          </div>
          <p class="text-base mt-4">Designed for individuals and solo creators to start.</p>
        </div>
      <% end %>

    </div>
  </div>
</section>

<section class="bg-prim h-64 flex flex-col items-center justify-center">
    <h1 class="font-sans text-3xl">Pay for impact. It’s the emails that matter.</h1>
    <%= link_to "Get started", "#pricing", class: "btn-getting bg-link-water mt-4 p-4" %>    
</section>

<section></section>

<footer class="p-4 bg-white mt-6">
    <div class="mx-auto max-w-screen-xl">
        <div class="flex justify-between">
            <div class="mb-0">
              <%= link_to root_path, class: "flex items-center" do %>
                <span class="self-center mt-3 font-logo text-2xl whitespace-nowrap">Piegon</span>
              <% end %>
              <div class="flex">
                <span class="mr-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E1D6DC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </span>
                <a href="mailto:arif@piegon.pro">arif@piegon.pro</a>
              </div>
            </div>
            <div class="grid grid-cols-3 gap-8">
                <div>
                    <h2 class="mb-6 text-base font-semibold">Resources</h2>
                    <ul>
                        <li class="mb-4">
                          <%= link_to "FAQ", "#", class: "hover:underline" %>
                        </li>
                        <li>
                          <%= link_to "Contact Us", "#", class: "hover:underline" %>
                        </li>
                    </ul>
                </div>
                <div>
                    <h2 class="mb-6 text-base font-semibold">Follow us</h2>
                    <ul>
                        <li class="mb-4">
                            <a href="#" class="hover:underline ">Twitter</a>
                        </li>
                        <li>
                            <a href="#" class="hover:underline">Facebook</a>
                        </li>
                    </ul>
                </div>
                <div>
                    <h2 class="mb-6 text-base font-semibold">Legal</h2>
                    <ul>
                        <li class="mb-4">
                          <%= link_to "Privacy Policy", privacy_policy_path , class: "hover:underline" %>
                        </li>
                        <li>
                          <%= link_to "Terms and Conditions", term_and_conditions_path, class: "hover:underline" %>                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <hr class="my-6 border-gray-200" />
        <div class="flex items-center justify-center">
            <span class="text-sm">© 2024 <%= link_to "Piegon", root_path, class: "hover:underline" %>. All Rights Reserved.</span>
        </div>
    </div>
</footer>