<section class="w-3xl">
  <div class="mb-4">
    <%= link_to "Back to Tickets", tickets_path, class: "btn btn-outline btn-sm" %>
  </div>

  <div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">
      <h2 class="card-title text-2xl"><%= @ticket.subject.capitalize %><span class="badge badge-outline"><%= @ticket.finished? ? "Closed" : "Open" %></span></h2>
      <div class="mt-2 text-base-content opacity-80">
        <p class="whitespace-pre-wrap"><%= @ticket.description %></p>
        <p class="text-sm opacity-60 mt-3"><%= l(@ticket.created_at, format: :long) %></p>
      </div>
    </div>
  </div>

  <h2 class="text-xl mb-2">Replies</h2>
  <% @replies.each do |reply| %>
  <div class="card <%= reply.user_id == Current.user.id ? 'bg-primary-content' : 'bg-base-100' %> shadow-sm">
    <div class="card-body">
      <div class="flex justify-between">
        <% if reply.user_id == Current.user.id %>
          <span class="badge badge-primary">You</span>
        <% else %>
          <span class="badge">Support</span>
        <% end %>
      </div>
      <p class="whitespace-pre-wrap"><%= reply.description %></p>
      <p class="text-sm opacity-60 mt-2"><%= l(reply.created_at, format: :long) %></p>
    </div>
  </div>
<% end %>

  <div class="mt-6">
    <div class="card bg-base-100 shadow-md">
      <div class="card-body">
        <h3 class="card-title text-lg">Add a Reply</h3>
        <%= form_with url: ticket_reply_path(@ticket), method: :post, class: "mt-3" do |form| %>
          <div class="form-control">
            <%= form.text_area :description, rows: 4, class: "textarea textarea-bordered", placeholder: "Your Reply" %>
          </div>
          <div class="form-control mt-4">
            <%= form.submit "Submit", class: "btn btn-neutral" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>