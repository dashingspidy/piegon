<section>
  <%= form_with model: campaign, data: { controller: "send-timing" } do |form| %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend">Campaign Name</legend>
      <%= form.text_field :name, class: "input" %>
      <%= campaign.errors[:name].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Select Contact list</legend>
      <%= form.select :contact_id, @contacts.map { |c| [c.name, c.id] }, {include_blank: "Select Contact list" }, { class: "select select-secondary" } %>
      <% if form.object.contact_id.present? %>
        <% contact = Contact.find(form.object.contact_id) %>
        <% subscriber_count = contact.subscribers.subscribed.count %>
        <div class="text-sm mt-2 p-2 bg-base-200 rounded">
          <strong>Email Cost Preview:</strong> This campaign will send to <%= number_with_delimiter(subscriber_count) %> subscribers
          <% if Current.user.can_send_emails?(subscriber_count) %>
            <span class="text-success">✓ You have enough credits</span>
          <% else %>
            <span class="text-error">⚠ Insufficient credits! You need <%= number_with_delimiter(subscriber_count) %> but only have <%= number_with_delimiter(Current.user.emails_remaining) %></span>
          <% end %>
        </div>
      <% end %>
      <%= campaign.errors[:contact_id].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend"> Select Email Template</legend>
      <%= form.select :email_template_id, @templates.map { |t| [t.name, t.id] }, {include_blank: "Select Email Template" }, { class: "select select-secondary" } %>
      <%= campaign.errors[:email_template_id].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">From Email</legend>
      <%= form.email_field :from, placeholder: "no-reply@piegon.pro", class: "input" %>
      <% verified_domains = Current.user.domain_verifications.verified %>
      <% if verified_domains.count > 1 %>
        <div class="mt-2">
          <label class="text-sm font-medium text-base-content/80">Send from domain:</label>
          <%= form.select :domain_verification_id, 
              options_from_collection_for_select(verified_domains, :id, :domain, campaign.domain_verification_id || verified_domains.first.id), 
              {}, 
              { class: "select select-secondary w-full mt-1" } %>
          <div class="text-sm text-success mt-1">
            ✓ You have <%= verified_domains.count %> verified domains available
          </div>
        </div>
      <% elsif verified_domains.any? %>
        <%= form.hidden_field :domain_verification_id, value: verified_domains.first.id %>
        <div class="text-sm text-success mt-1">
          ✓ Will send from: <strong><%= verified_domains.first.domain %></strong>
        </div>
      <% else %>
        <div class="text-sm text-error mt-1">
          ⚠ Will send from: <strong>piegon.pro</strong> (default) - 
          <%= link_to "Verify your domain", new_domain_verification_path, class: "link link-neutral" %>
          for better deliverability
        </div>
      <% end %>
      <%= campaign.errors[:from].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Header</legend>
      <%= form.text_field :header, placeholder: "Arif from Piegon", class: "input" %>
      <%= campaign.errors[:header].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Subject</legend>
      <%= form.text_field :subject, placeholder: "Black Friday sale", class: "input" %>
      <%= campaign.errors[:subject].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset flex gap-4 mb-4">
      <legend class="fieldset-legend">When do you want to send the campaign?</legend>
      <label class="text-[1rem]">
        <%= form.radio_button :send_time_option, "now", checked: true, class: "radio", data: { action: "send-timing#toggle" } %>
        Send now
      </label>
      <label class="text-[1rem]">
        <%= form.radio_button :send_time_option, "later", class: "radio", data: { action: "send-timing#toggle" } %>
        Send later
      </label>
      <%= campaign.errors[:send_time_option].first if campaign.errors.any? %>
    </fieldset>

    <fieldset class="fieldset" data-send-timing-target="scheduleField" hidden>
      <legend class="fieldset-legend">Select Date</legend>
      <%= form.date_field :send_at, class: "input" %>
      <%= campaign.errors[:send_at].first if campaign.errors.any? %>
    </fieldset>

    <%= form.submit campaign.persisted? ? "Update Campaign" : "Start Campaign", class: "btn btn-neutral" %>
  <% end %>
</section>
