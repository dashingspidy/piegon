<section class="flex flex-col">
  <h1 class="text-primary-900 text-2xl">List of campaigns</h1>
  <hr class="h-px my-2 bg-primary-900 border-0">
  <div class="grid grid-flow-col auto-cols-max gap-4 my-6">
    <% @campaigns.each do |campaign| %>
      <%= link_to campaign_subscribers_path(campaign), class: "p-3 text-primary-900 bg-white text-center border border-primary-200 rounded-lg shadow hover:bg-primary-100" do %>
        <span class="mb-2 text-2xl tracking-tight"><%= campaign.name %> (<%= number_to_k(campaign.subscribers.size) %>)</span>
      <% end %>
    <% end %>
  </div>
  <div>
    <%= link_to "Create a new campaign", new_campaign_path, class: "w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center" %>
  </div>
</section>
