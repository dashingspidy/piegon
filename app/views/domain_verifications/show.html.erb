<section class="w-full max-w-4xl">
  <%= link_to "← Back to Domains", domain_verifications_path, class: "btn btn-ghost" %>
  <div class="bg-base-100 rounded-box shadow-md p-8">
    <div class="flex justify-between items-start mb-6">
      <div>
        <h1 class="text-2xl font-bold mb-2"><%= @domain_verification.domain %></h1>
        <div class="flex items-center gap-2">
          <% case @domain_verification.verification_status %>
          <% when 'verified' %>
            <div class="badge badge-success gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Verified
            </div>
            <span class="text-sm text-base-content/60">
              Verified <%= time_ago_in_words(@domain_verification.verified_at) %> ago
            </span>
          <% when 'pending' %>
            <div class="badge badge-warning gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
              Pending Verification
            </div>
          <% when 'failed' %>
            <div class="badge badge-error gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              Verification Failed
            </div>
          <% end %>
        </div>
      </div>
      
      <div class="flex gap-2">
        <% unless @domain_verification.verified? %>
          <%= button_to "Check Status", check_status_domain_verification_path(@domain_verification), method: :post, class: "btn btn-secondary" %>
          <%= button_to "Verify Now", verify_domain_verification_path(@domain_verification), method: :post, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>

    <% if @domain_verification.verified? %>
      <div class="alert alert-success mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <div>
          <h3 class="font-bold">Domain Verified Successfully!</h3>
        </div>
      </div>
    <% else %>
      <div class="alert alert-error mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <div>
          <h3 class="font-bold">DNS Configuration Required</h3>
          <div class="text-xs">Add the DNS records below to your domain's DNS settings to complete verification.</div>
        </div>
      </div>
    <% end %>

    <% if @domain_verification.dns_records.present? %>
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-4">DNS Records to Add</h2>
        <p class="text-sm text-base-content/70 mb-4">
          Add these DNS records to your domain's DNS settings. It may take up to 48 hours for DNS changes to propagate.
        </p>
        
        <div class="overflow-x-auto">
          <table class="table w-full">
            <thead>
              <tr>
                <th>Type</th>
                <th>Host/Name</th>
                <th>Value/Points To</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% @domain_verification.dns_records.each_with_index do |record, index| %>
                <tr>
                  <td>
                    <span class="badge badge-outline"><%= record['type'] %></span>
                  </td>
                  <td>
                    <code class="text-xs bg-base-200 px-2 py-1 rounded"><%= record['host'] %></code>
                  </td>
                  <td>
                    <code class="text-xs bg-base-200 px-2 py-1 rounded break-all"><%= record['value'] %></code>
                  </td>
                  <td>
                    <button class="btn btn-xs btn-ghost" onclick="copyToClipboard('<%= record['value'] %>', this)">
                      Copy
                    </button>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <div class="bg-base-200 rounded-lg p-4">
      <h3 class="font-semibold mb-2">Instructions:</h3>
      <ol class="list-decimal list-inside space-y-1 text-sm text-base-content/80">
        <li>Log in to your domain registrar or DNS provider</li>
        <li>Navigate to the DNS management section</li>
        <li>Add each DNS record shown above</li>
        <li>Wait for DNS propagation (up to 48 hours)</li>
        <li>Click "Verify Now" to check if your domain is verified</li>
      </ol>
    </div>

    <div class="mt-6 pt-4 border-t border-base-300">
      <div class="text-sm text-base-content/60">
        <p><strong>Domain ID:</strong> <%= @domain_verification.sendgrid_domain_id || 'Not assigned' %></p>
        <p><strong>Added:</strong> <%= l(@domain_verification.created_at, format: :long) %></p>
        <% if @domain_verification.verified_at %>
          <p><strong>Verified:</strong> <%= l(@domain_verification.verified_at, format: :long) %></p>
        <% end %>
      </div>
    </div>
  </div>
</section>

<script>
function copyToClipboard(text, button) {
  navigator.clipboard.writeText(text).then(function() {
    const originalText = button.textContent;
    button.textContent = 'Copied!';
    button.classList.add('btn-success');
    setTimeout(function() {
      button.textContent = originalText;
      button.classList.remove('btn-success');
    }, 2000);
  });
}
</script> 