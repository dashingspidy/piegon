<section class="bg-white">
  <div>
    <%= form_with model: @email_template do |form| %>
      <div class="flex justify-between">
        <h2 class="mb-4 text-xl">Copy-Paste you html template</h2>
        <div class="flex gap-2">
          <div class="flex flex-col">
            <%= form.text_field :name, placeholder: "Template name", class: "border border-lavender-gray text-sm focus:ring-lavender-gray focus:border-lavender-gray w-full p-2.5" %>
            <%= @email_template.errors[:name].first if @email_template.errors.any? %>
          </div>
          <%= form.hidden_field :editor, value: "html" %>
          <%= form.submit "Submit", class: "w-32 h-10 font-medium text-center bg-link-water hover:bg-lavender-gray" %>
        </div>
      </div>
      <div class="mt-3">
        <%= form.textarea :body, 
            is: "highlighted-code",
            language: "html",
            placeholder: "// start here",
            data: { controller:"color-code" },
            class: "bg-gray-50 border-none w-full h-[87vh] overflow-y-auto resize-none focus:ring-0" %>
      </div>
    <% end %>
  </div>
</section>