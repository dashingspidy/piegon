<h1 class="text-xl">New email template</h1>
<div class="my-8">
  <%= link_to "Drag and drop editor", 
     draganddrop_email_templates_path,
    class: "px-6 py-3.5 font-medium bg-link-water hover:bg-lavender-gray focus:ring-4 focus:outline-none focus:ring-lavender-gray text-center" 
  %>
  <%= link_to "Copy-paste your own html template", 
    new_email_template_path,
    class: "px-6 py-3.5 font-medium bg-link-water hover:bg-lavender-gray focus:ring-4 focus:outline-none focus:ring-lavender-gray text-center" 
  %>
</div>
<hr>
<section class="my-5">
  <h1 class="text-xl">Your Templates</h1>
</section>
<section class="grid grid-cols-4 gap-4">
    <% @email_templates.each do |email| %>
      <div class="flex-col justify-between">
        <div class="p-2 border-2 h-10 text-center">
          <%= link_to "#{email.name}", "#" %>
        </div>
        <div class="flex justify-between m-1">
          <%= link_to "Edit", edit_email_template_path(email), class: "bg-link-water p-2 rounded-md" %>
          <%= button_to "Delete", email_template_path(email), method: :delete, data: { turbo_confirm: "Are you sure?"}, class: "bg-red-500 p-2 rounded-md" %>
        </div>
      </div>
    <% end %>
</section>