<% if @email_template.editor == "draganddrop" %>
  <div data-controller="email-editor">
    <div class="flex items-end justify-end gap-1 mb-1">
      <input type="text" 
        placeholder="Enter template name"
        data-email-editor-target="name"
        required
        class="input">
      <button
        class="btn"
        data-action="click->email-editor#saveHtml">Update</button>
    </div>
    <div class="flex items-end justify-end">
      <span class="text-sm text-red-600" data-email-editor-target="error"></span>
    </div>
    <div id="editor" class="h-[700px]" data-template-id="<%= @email_template.id %>"></div>
  </div>
<% else %>
  <section>
    <div>
      <%= form_with model: @email_template do |form| %>
        <div class="flex justify-between">
          <legend class="fieldset-legend">Template Code (HTML)</legend>
          <div class="flex gap-2">
            <div class="flex flex-col">
              <%= form.text_field :name, class: "input" %>
              <%= @email_template.errors[:name].first if @email_template.errors.any? %>
            </div>
            <%= form.hidden_field :editor, value: "html" %>
            <%= form.submit "Update", class: "btn" %>
          </div>
        </div>
        <div class="mt-3">
          <%= form.textarea :body, 
              is: "highlighted-code",
              language: "html",
              placeholder: "// start here",
              data: { controller:"color-code" },
              class: "input w-full h-[87vh] overflow-y-auto resize-none" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>