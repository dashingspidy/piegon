<section>
  <div class="flex flex-col items-center justify-center px-6 mx-auto h-screen">
      <div class="w-full rounded-lg shadow max-w-md p-0">
          <div class="p-8 space-y-6">
              <h1 class="text-xl font-bold leading-tight tracking-tight">
                  Forgot your password?
              </h1>
              <%= form_with url: passwords_path, class: "space-y-6" do |form| %>
                <div>
                  <%= form.email_field :email_address, required: true, autofocus: true, placeholder: "Enter your email address", value: params[:email_address], class: "border border-lavender-gray focus:ring-lavender-gray focus:border-lavender-gray block w-full p-2.5" %>
                  </div>
                <%= form.submit "Email reset instructions", class: "w-full bg-link-water hover:bg-lavender-gray focus:ring-4 focus:outline-none focus:ring-lavender-gray font-medium px-5 py-2.5 text-center" %>
              <% end %>
          </div>
      </div>
  </div>
</section>