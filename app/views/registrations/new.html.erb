<section>
  <div class="flex flex-col items-center justify-center px-6 py-0 mx-auto h-screen">
      <div class="w-full rounded-lg shadow max-w-md">
          <div class="p-6 space-y-6">
              <h1 class="text-xl font-bold leading-tight tracking-tight">
                  Create an account
              </h1>
              <%= form_with(model: @user, url: registration_path, local: true, data: { turbo: false }, class: "space-y-6") do |form| %>
                <% if @user.errors.any? %>
                  <div id="error_explanation">
                    <h2><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
                    <ul>
                      <% @user.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>
                <div>
                  <%= form.hidden_field :plan, value: params[:plan] %>
                </div>

                <div>
                  <%= form.email_field :email_address, required: true, autofocus: true, placeholder: "Enter your email address", value: params[:email_address], class: "border border-lavender-gray text-sm focus:ring-lavender-gray focus:border-lavender-gray block w-full p-2.5" %>
                </div>

                <div>
                  <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "border border-lavender-gray text-sm focus:ring-lavender-gray focus:border-lavender-gray block w-full p-2.5" %>
                </div>

                <div>
                  <%= form.password_field :password_confirmation, required: true, autocomplete: "current-password", placeholder: "Confirm password", maxlength: 72, class: "border border-lavender-gray text-sm focus:ring-lavender-gray focus:border-lavender-gray block w-full p-2.5" %>
                </div>

                <%= form.submit "Register", class: "w-full bg-link-water hover:bg-lavender-gray focus:ring-4 focus:outline-none focus:ring-lavender-gray font-medium px-5 py-2.5 text-center" %>
              <% end %>
              <p class="text-sm font-light">
                Already have an account? <%= link_to "Login", new_session_path, class: "font-medium hover:underline" %>
              </p>
          </div>
      </div>
  </div>
</section>