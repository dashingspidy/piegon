<aside id="default-sidebar" class="w-60 h-screen translate-x-0" aria-label="Sidenav">
  <div class="overflow-y-auto py-5 px-3 h-full bg-white border-r border-gray-200">
      <%= link_to root_path, class: "flex items-center mb-6 justify-center" do %>
        <span class="-mt-4"><%= image_tag "logo.svg", width: 45 %></span>
        <span class="self-center mt-3 font-logo text-2xl whitespace-nowrap">Piegon</span>
      <% end %>
      <ul class="space-y-2">
          <li>
            <%= link_to dashboard_path, class: ["flex items-center p-2 text-base font-normal transition duration-75 hover:bg-prim", active_link(dashboard_path)] do %>
              <%= image_tag "dashboard.svg" %>
              <span class="ml-3">Dashboard</span>
            <% end %>
          </li>
          <li>
            <%= link_to campaigns_path, class: ["flex items-center p-2 text-base font-normal transition duration-75 hover:bg-prim", active_link(campaigns_path)] do %>
              <%= image_tag "megaphone.svg" %>
              <span class="ml-3">Campaign</span>
            <% end %>
          </li>
          <li>
            <%= link_to email_templates_path, class: ["flex items-center p-2 text-base font-normal transition duration-75 hover:bg-prim", active_link(email_templates_path)] do %>
              <%= image_tag "template.svg" %>
              <span class="ml-3">Email Template</span>
            <% end %>
          </li>
      </ul>
      <ul class="pt-5 mt-5 space-y-2 border-t border-gray-200">
          <li>
            <%= link_to "#", class: "flex items-center p-2 text-base font-normal transition duration-75 hover:bg-prim" do %>
              <%= image_tag "user.svg" %>
              <span class="ml-3">Account</span>
            <% end %>
          </li>
          <li>
            <%= link_to help_path, class: "flex items-center p-2 text-base font-normal transition duration-75 hover:bg-prim" do %>
              <%= image_tag "help.svg" %>
              <span class="ml-3">Help</span>
            <% end %>
          </li>
      </ul>
  </div>
  <div class="hidden absolute bottom-0 left-0 justify-center p-4 space-x-4 w-full lg:flex bg-white z-20 border-r border-gray-200">
      <%= link_to session_path, data: { turbo_method: :delete, tooltip_target: "tooltip-logout" }, class: "inline-flex justify-center p-2 text-chambray rounded cursor-pointer hover:text-gray-900 hover:bg-gray-100" do %>
        <svg class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H4m12 0-4 4m4-4-4-4m3-4h2a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3h-2"/>
        </svg>
      <% end %>
      <div id="tooltip-logout" role="tooltip" class="inline-block absolute invisible z-10 py-2 px-3 text-sm font-medium bg-prim rounded-lg shadow-sm opacity-0 transition-opacity duration-300 tooltip">
        Log out
          <div class="tooltip-arrow" data-popper-arrow></div>
      </div>
  </div>
</aside>
