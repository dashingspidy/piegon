<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #464e7f;
        background-color: white;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        background-color: white;
        border-radius: 8px;
        border: 1px solid #C0C8DB;
      }
      .header {
        text-align: center;
        padding-bottom: 20px;
        border-bottom: 1px solid #C0C8DB;
      }
      .content {
        padding: 20px 0;
      }
      .footer {
        text-align: center;
        font-size: 12px;
        color: #838BAD;
        padding-top: 20px;
        border-top: 1px solid #C0C8DB;
      }
      .btn {
        display: inline-block;
        padding: 10px 20px;
        background-color: #464e7f;
        color: white !important;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        margin: 20px 0;
      }
      .logo {
        max-width: 150px;
        margin-bottom: 15px;
      }
      a {
        color: #464e7f;
        text-decoration: underline;
      }
      p {
        margin: 16px 0;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="header">
        <img src="<%= attachments['logo-email.png'].url %>" alt="Piegon - Email Marketing Platform" class="logo">
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        <p>&copy; <%= Time.now.year %> Piegon. All rights reserved.</p>
        <p>If you need assistance, please contact at arif@piegon.pro</p>
      </div>
    </div>
  </body>
</html>