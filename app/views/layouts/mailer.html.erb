<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #000000;
        background-color: #ffffff;
        margin: 0;
        padding: 20px;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
      }
      .header {
        text-align: center;
        padding-bottom: 20px;
        border-bottom: 2px solid #000000;
        margin-bottom: 30px;
      }
      .content {
        padding: 0;
      }
      .footer {
        text-align: center;
        font-size: 12px;
        color: #666666;
        padding-top: 30px;
        border-top: 1px solid #cccccc;
        margin-top: 30px;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background-color: #000000;
        color: #ffffff !important;
        text-decoration: none;
        border: 2px solid #000000;
        font-weight: bold;
        margin: 20px 0;
      }
      .btn:hover {
        background-color: #ffffff;
        color: #000000 !important;
      }
      .logo {
        font-size: 24px;
        font-weight: bold;
        color: #000000;
        text-decoration: none;
      }
      a {
        color: #000000;
        text-decoration: underline;
      }
      p {
        margin: 16px 0;
        color: #000000;
      }
      h1, h2, h3 {
        color: #000000;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="header">
        <div class="logo">Piegon</div>
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        <p>&copy; <%= Time.now.year %> Piegon. All rights reserved.</p>
        <p>Need help? Contact us at arif@piegon.pro</p>
      </div>
    </div>
  </body>
</html>