<header class="sticky top-0 z-50 bg-white">
  <nav class="border-gray-200 px-6 py-2.5 mt-2">
    <div class="flex flex-wrap justify-between mx-auto max-w-screen-xl">
      <%= link_to root_path, class: "flex items-center" do %>
        <span class="-mt-4"><%= image_tag "logo.svg", width: 45 %></span>
        <span class="self-center mt-3 font-logo text-2xl whitespace-nowrap">Piegon</span>
      <% end %>
      <div class="flex flex-row gap-3 order-2">
        <%= link_to "Log in", new_session_path, class: "btn-getting" %>
        <%= link_to "Get started", "#pricing", class: "btn-getting bg-prim" %>
      </div>
      <div>
        <ul class="flex flex-row mt-0 space-x-8">
          <li>
            <%= link_to "Home", "#{root_path}#home", class: "block py-2 pr-2 pl-2 text-black rounded hover:bg-gray-100" %>
          </li>
          <li>
            <%= link_to "Features", "#{root_path}#features", class: "block py-2 pr-2 pl-2 text-black rounded hover:bg-gray-100" %>
          </li>
          <li>
            <%= link_to "Pricing", "#{root_path}#pricing", class: "block py-2 pr-2 pl-2 text-black rounded hover:bg-gray-100" %>
          </li>
          <li>
            <%= link_to "Contact", "#{root_path}#", class: "block py-2 pr-2 pl-2 text-black rounded hover:bg-gray-100" %>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
