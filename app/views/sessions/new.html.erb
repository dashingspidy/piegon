<section>
  <div class="flex flex-col items-center justify-center px-6 py-8 mx-auto md:h-screen lg:py-0">
      <a href="#" class="flex items-center mb-6 text-2xl font-semibold text-gray-900">
          <img class="w-8 h-8 mr-2" src="" alt="logo">
          Piegon    
      </a>
      <div class="w-full bg-white rounded-lg shadow dark:border md:mt-0 sm:max-w-md xl:p-0">
          <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
              <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl">
                  Sign in to your account
              </h1>
              <%= form_with url: session_path, class: "space-y-4 md:space-y-6" do |form| %>
                <div>
                  <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", value: params[:email_address], class: "bg-gray-50 border border-gray-300 text-gray-900 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5" %>
                </div>

                <div>
                  <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "bg-gray-50 border border-gray-300 text-gray-900 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5" %>
                </div>

                <div class="flex items-center">
                  <%= link_to "Forgot password?", new_password_path, class: "text-sm font-medium text-primary-600 hover:underline" %>
                </div>

                <%= form.submit "Sign in", class: "w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center" %>
              <% end %>

              <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                  Don’t have an account yet? <%= link_to "Register", new_registration_path, class: "font-medium text-primary-600 hover:underline" %>
              </p>
          </div>
      </div>
  </div>
</section>





