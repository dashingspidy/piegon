<section>
  <h1 class="text-2xl font-bold">Usage</h1>
  <p>Current Plan: <span class="font-black text-xl"><%= Current.user.plan %></span></p>
  <p class="mt-2 text-base-content/70">Payment and checkout integrations have been removed from this open-source version.</p>
</section>

<div class="mt-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="stat bg-primary text-primary-content rounded-lg">
      <div class="stat-title text-primary-content/70">Plan Limit</div>
      <div class="stat-value text-2xl"><%= number_with_delimiter(@email_usage&.dig(:limit) || 0) %></div>
      <div class="stat-desc text-primary-content/70">per period</div>
    </div>

    <div class="stat bg-secondary text-secondary-content rounded-lg">
      <div class="stat-title text-secondary-content/70">Additional Credits</div>
      <div class="stat-value text-2xl"><%= number_with_delimiter(@email_usage&.dig(:additional) || 0) %></div>
      <div class="stat-desc text-secondary-content/70">legacy field</div>
    </div>

    <div class="stat bg-accent text-accent-content rounded-lg">
      <div class="stat-title text-accent-content/70">Emails Sent</div>
      <div class="stat-value text-2xl"><%= number_with_delimiter(@email_usage&.dig(:sent) || 0) %></div>
      <div class="stat-desc text-accent-content/70">current period</div>
    </div>

    <div class="stat bg-neutral text-neutral-content rounded-lg">
      <div class="stat-title text-neutral-content/70">Remaining</div>
      <div class="stat-value text-2xl"><%= number_with_delimiter(@email_usage&.dig(:remaining) || 0) %></div>
      <div class="stat-desc text-neutral-content/70">available now</div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-xl">Plan Details</h2>
      <p class="text-base-content/70">This page is informational in the open-source version. If you want plan upgrades, credits, or billing, wire your own provider and update the related account flows.</p>

      <% plan_limits = Plan::LIMITS[Current.user.plan] %>
      <% if plan_limits %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
          <div>
            <h3 class="font-semibold text-lg mb-3">Limits</h3>
            <ul class="space-y-2">
              <li><span class="font-medium">Websites:</span> <%= plan_limits[:contacts] == Float::INFINITY ? "Unlimited" : plan_limits[:contacts] %></li>
              <li><span class="font-medium">Emails:</span> <%= number_with_delimiter(plan_limits[:email_limit]) %> per period</li>
              <li><span class="font-medium">Templates:</span> <%= plan_limits[:email_templates] == Float::INFINITY ? "Unlimited" : plan_limits[:email_templates] %></li>
              <li><span class="font-medium">Campaigns:</span> <%= plan_limits[:campaigns] == Float::INFINITY ? "Unlimited" : plan_limits[:campaigns] %></li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold text-lg mb-3">Usage Summary</h3>
            <ul class="space-y-2">
              <li><span class="font-medium">Total available emails:</span> <%= number_with_delimiter(@email_usage&.dig(:total_available) || 0) %></li>
              <li><span class="font-medium">Usage percentage:</span> <%= @email_usage&.dig(:usage_percentage) || 0 %>%</li>
              <li><span class="font-medium">Plan:</span> <%= Current.user.plan.titleize %></li>
            </ul>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
